## Auth (required for /login and all CRM routes)
# Random string, min 16 chars, e.g. openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-for-jwt"
# Session cookie Secure flag. Set true only when the app is served over HTTPS.
# Leave unset or false for http://host:3001 style deploys.
# COOKIE_SECURE=true

# If POST /api/leads must hit a fixed host (same as curl), set full URL:
# NEXT_PUBLIC_LEADS_API_URL=http://144.91.117.236:3001/api/leads
# Default: same origin as the page (window.location.origin + /api/leads).

## Database
# Local Postgres (see docker-compose.yml)
DATABASE_URL="postgresql://arkadians:arkadians@localhost:5432/arkadians_crm?schema=public"

# After migrate, load demo data (pipeline, leads, calls, activities):
# npm run db:seed
# Or: npx prisma db seed

# Hosted Postgres (Neon / Supabase / RDS): use the provider's connection string and add SSL if required, e.g.
# ?sslmode=require
# Prefer a pooler URL for serverless (Vercel) so API routes do not hang on "too many connections".

